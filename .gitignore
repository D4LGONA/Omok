# This .gitignore file should be placed at the root of your Unity project
# Unity-generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/

# Asset meta data should only be ignored when the corresponding asset is ignored
!/[Aa]ssets/**/*.meta
!/[Pp]ackages/**/*.meta
!/[Pp]rojectSettings/**/*.meta

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/

# Rider
/[Aa]ssets/Plugins/Editor/JetBrains*
.idea/

# VS Code
.vscode/

# OS generated files
.DS_Store
Thumbs.db
Desktop.ini

# If collaborating with packages, keep Packages/packages-lock.json
# If using generated IDE files intentionally, remove those rules above.
/Omok_Server/.vs/Omok_Server/CopilotIndices
/Omok_Server/.vs/Omok_Server/FileContentIndex
/Omok_Server/.vs
/Unity_Omok/.vs
